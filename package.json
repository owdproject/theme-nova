{
  "name": "@owdproject/theme-nova",
  "version": "0.0.2",
  "description": "Open Web Desktop theme",
  "homepage": "https://github.com/owdproject/theme-nova",
  "license": "MIT",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "development": "./src/module.ts",
      "import": "./dist/module.mjs",
      "default": "./dist/module.mjs"
    },
    "./runtime/*": {
      "types": "./src/runtime/*",
      "development": "./src/runtime/*",
      "import": "./src/runtime/*",
      "default": "./src/runtime/*"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "nx": {
    "name": "theme-nova"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/theme-nova/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6",
    "@primeuix/themes": "^2.0.3",
    "primevue": "^4.5.5",
    "@owdproject/kit-explorer": "^0.0.4",
    "@owdproject/kit-theme": "^0.0.4",
    "defu": "^6.1.7",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@owdproject/core": "^3.3.1",
    "@owdproject/app-about": "^0.1.3",
    "@owdproject/app-terminal": "^0.1.3",
    "@owdproject/module-fs": "^0.0.6",
    "@owdproject/app-classic-audioplayer": "^0.0.4",
    "@owdproject/app-classic-videoplayer": "^0.0.4",
    "nuxt": "^4.4.6",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.3.0",
    "@owdproject/kit-explorer": "^0.0.4",
    "@owdproject/kit-theme": "^0.0.4",
    "@owdproject/module-fs": "^0.0.6",
    "nuxt": "^4.4.4"
  }
}
